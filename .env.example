# Copy this file to ".env" and fill in your values. NEVER commit .env.

# Anthropic API key — from https://console.anthropic.com (Settings -> API keys)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Pedagogy model. Default is Sonnet 4.6 (best value).
# Options: claude-sonnet-4-6 | claude-opus-4-8 | claude-fable-5
ARUVI_MODEL=claude-sonnet-4-6

# Parent email(s) for the post-session PDF report (comma-separated)
PARENT_EMAILS=raveykumar@yahoo.com
